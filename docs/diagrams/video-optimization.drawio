    <mxCell id="code" value="while True:&#xa;    chunk = remote.read(65536)  # 64KB 分块&#xa;    if not chunk:&#xa;        break&#xa;    self.wfile.write(chunk)     # 立即写入&#xa;    self.wfile.flush()        # 强制刷新" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontFamily=Courier New;fontColor=#333333;" vertex="1" parent="1">
